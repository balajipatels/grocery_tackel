# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection string (pooled endpoint)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/groceryos?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-char-random-secret-here"

# First user to sign in with this email is auto-promoted to ADMIN
ADMIN_EMAILS="balajipatel86@gmail.com,shrujana.s2025@gmail.com"

# ─── Google OAuth (optional - only needed if using Google sign-in) ──────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI (optional — Claude via Anthropic) ───────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Redis Cache (optional — Upstash) ────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Firebase Analytics ──────────────────────────────────────────────────────
