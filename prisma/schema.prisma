generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  image        String?
  emailVerified DateTime?
  role         Role       @default(STAFF)
  authProvider String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  investor     Investor?
  createdBills Bill[]
  auditLogs    AuditLog[]
  accounts     Account[]
  sessions     Session[]
  @@map("users")
}

enum Role {
  ADMIN
  VENDOR
  STAFF
  INVESTOR
}

model Investor {
  id             String               @id @default(cuid())
  userId         String               @unique
  user           User                 @relation(fields: [userId], references: [id])
  displayName    String
  investedAmount Float
  investmentDate DateTime
  colorTag       String               @default("#1D9E75")
  isActive       Boolean              @default(true)
  notes          String?
  createdAt      DateTime             @default(now())
  billShares     InvestorBillShare[]
  profitRecords  ProfitDistribution[]
  @@map("investors")
}

model Category {
  id             String    @id @default(cuid())
  name           String    @unique
  cgstPercent    Float     @default(0)
  sgstPercent    Float     @default(0)
  isQuickService Boolean   @default(false)
  colorHex       String    @default("#1B4332")
  iconName       String    @default("shopping-cart")
  products       Product[]
  createdAt      DateTime  @default(now())
  @@map("categories")
}

model Product {
  id           String             @id @default(cuid())
  name         String
  sku          String?            @unique
  barcode      String?            @unique
  categoryId   String
  category     Category           @relation(fields: [categoryId], references: [id])
  buyingPrice  Float
  sellingPrice Float
  mrp          Float
  stockQty     Int                @default(0)
  reorderLevel Int                @default(10)
  unit         String             @default("pcs")
  imageUrl     String?
  isActive     Boolean            @default(true)
  expiryDate   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  billItems    BillItem[]
  stockTxns    StockTransaction[]
  @@map("products")
}

model Bill {
  id             String              @id @default(cuid())
  billNumber     String              @unique
  customerName   String?
  customerPhone  String?
  subtotal       Float
  totalCgst      Float
  totalSgst      Float
  totalCogs      Float
  discountAmount Float               @default(0)
  grandTotal     Float
  paymentMethod  PaymentMethod       @default(CASH)
  status         BillStatus          @default(PAID)
  createdAt      DateTime            @default(now())
  createdById    String
  createdBy      User                @relation(fields: [createdById], references: [id])
  items          BillItem[]
  investorShares InvestorBillShare[]
  @@map("bills")
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

enum BillStatus {
  PAID
  PENDING
  CANCELLED
}

model BillItem {
  id           String  @id @default(cuid())
  billId       String
  bill         Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  productName  String
  quantity     Int
  buyingPrice  Float
  sellingPrice Float
  cgstPercent  Float
  sgstPercent  Float
  cgstAmount   Float
  sgstAmount   Float
  lineTotal    Float
  @@map("bill_items")
}

model InvestorBillShare {
  id           String   @id @default(cuid())
  billId       String
  bill         Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  investorId   String
  investor     Investor @relation(fields: [investorId], references: [id])
  sharePercent Float
  revenueShare Float
  cogShare     Float
  profitShare  Float
  createdAt    DateTime @default(now())
  @@map("investor_bill_shares")
}

model StockTransaction {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  type        StockTxnType
  quantity    Int
  previousQty Int
  newQty      Int
  notes       String?
  createdAt   DateTime     @default(now())
  createdById String?
  @@map("stock_transactions")
}

enum StockTxnType {
  STOCK_IN
  SALE
  ADJUSTMENT
  DAMAGE
  RETURN
}

model Expense {
  id          String      @id @default(cuid())
  category    ExpenseType
  amount      Float
  description String
  date        DateTime
  createdAt   DateTime    @default(now())
  @@map("expenses")
}

enum ExpenseType {
  RENT
  ADVANCE
  UTILITIES
  SALARIES
  MAINTENANCE
  OTHER
}

model ProfitDistribution {
  id              String   @id @default(cuid())
  investorId      String
  investor        Investor @relation(fields: [investorId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  grossRevenue    Float
  totalCogs       Float
  grossProfit     Float
  totalExpenses   Float
  expenseShare    Float
  netProfit       Float
  sharePercentage Float
  createdAt       DateTime @default(now())
  @@map("profit_distributions")
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  productId String?
  createdAt DateTime @default(now())
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())
  @@map("audit_logs")
}
